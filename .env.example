# White Star Market Intelligence Hub — environment variables
# Copy to .env.local (never committed), fill in your values.
# .env.local is gitignored. This file is committed as documentation.

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=wsuser
POSTGRES_PASSWORD=wspass
POSTGRES_DB=wshub
DATABASE_URL=postgresql+asyncpg://wsuser:wspass@localhost:5432/wshub

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
# Optional: REDIS_PASSWORD=yourpassword

# ── Application ───────────────────────────────────────────────────────────────
ENV=development
SECRET_KEY=local-dev-secret-change-before-sharing
LOG_LEVEL=INFO

# ── Anthropic / Claude ────────────────────────────────────────────────────────
# THIS IS THE ONLY SECRET YOU NEED TO FILL IN
ANTHROPIC_API_KEY=sk-ant-api03-...
CLAUDE_MONTHLY_BUDGET_USD=50.0
CLAUDE_DAILY_BUDGET_USD=5.0

# ── Blob storage (local filesystem) ───────────────────────────────────────────
# "local" → writes to ./data/raw/ (default for local development)
# "s3"    → S3BlobStore (not yet implemented; see README → Going to production)
BLOB_STORE_BACKEND=local
# BLOB_STORE_LOCAL_ROOT=./data/raw  # default, can override

# ── Scraping ─────────────────────────────────────────────────────────────────
# false = no live HTTP calls (for development / running tests offline)
# true  = hits real URLs (requires proxy for REGA + Aqar)
SCRAPER_LIVE_MODE=false

# Optional: KSA residential proxy for REGA and Aqar (improves success rate)
# KSA_PROXY_URL=http://user:pass@host:port

# ── Auth (single local user, seeded by migration) ────────────────────────────
ADMIN_EMAIL=admin@local
ADMIN_PASSWORD=change-me-immediately

# ── Etimad API (optional, for tender tracking) ────────────────────────────────
# ETIMAD_CLIENT_ID=
# ETIMAD_CLIENT_SECRET=

# ── Spatial / OpenRouteService ────────────────────────────────────────────────
# Required for isochrone overlays on the Workbench map.
# Free tier at https://openrouteservice.org covers local development usage.
# Without this key the /api/spatial/isochrone endpoint returns 503.
ORS_API_KEY=
